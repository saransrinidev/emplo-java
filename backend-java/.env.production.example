# ============================================================
# Production Environment Variables (Emplo HRMS)
# Copy to .env.production and fill in real values.
# NEVER commit this file with real credentials.
# ============================================================

# Database (REQUIRED — no defaults in production)
DATABASE_URL=jdbc:postgresql://your-host:5432/hr_portal?sslmode=require
DB_USERNAME=emplo_app
DB_PASSWORD=

# JWT Secret (REQUIRED — minimum 64 random characters)
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Spring Profile
SPRING_PROFILES_ACTIVE=production

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@yourcompany.com

# AI Chat (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Data Retention
RETENTION_ENABLED=true
RETENTION_SENSITIVE_DOCS_YEARS=7
RETENTION_PERSONAL_DATA_YEARS=7

# HikariCP
HIKARI_MAX_POOL=10
